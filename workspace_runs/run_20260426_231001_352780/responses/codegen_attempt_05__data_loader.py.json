  "content": "```python\nimport pandas as pd\n\ndef load_data(input_dir):\n    # Load Sales Data CSV file from the provided input directory.\n    sales_file = f\"{input_dir}/Warehouse_and_Retail_Sales.csv\"\n    sales_data = pd.read_csv(sales_file, parse_dates=[\"YEAR\", \"MONTH\"], index_col=\"YEAR\")\n    \n    # Aggregate RETAIL SALES data into a DataFrame for clearer analysis.\n    monthly_sales = pd.DataFrame()\n    for _, row in sales_data.iterrows():\n        key = f\"{row['YEAR']:04}{row['MONTH']:02}\"\n        month_key = f\"{sales_file}_{key}.csv\"\n        month_df = pd.read_csv(month_key)\n        monthly_sales[key] = month_df['RETAIL SALES']\n    \n    # Generate Supplier Summary DataFrame for categorical insights.\n    supplier_summary = sales_data.groupby('SUPPLIER').agg({\n        'SUPPLIER': lambda x: set(x['SUPPLIER']),\n        'ITEM TYPE': lambda x: set(x['ITEM TYPE'])\n    })\n    # Aggregate counts per supplier and item type across all months.\n    \n    return {\n        \"sales_data\": sales_data,\n        \"monthly_sales\": monthly_sales,\n        \"supplier_summary\": supplier_summary\n    }\n```",
