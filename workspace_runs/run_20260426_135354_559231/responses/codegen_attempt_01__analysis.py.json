    "response": "import pandas as pd\nimport matplotlib.pyplot as plt\nimport data_loader\nimport preprocessing\nimport figures\n\ndef run_analysis(file_path: str):\n    \"\"\"\n    Runs the complete analysis pipeline: loading, preprocessing, analysis, and visualization.\n\n    Args:\n        file_path: The path to the sales data file.\n    \"\"\"\n    print(\"--- Starting Data Analysis Pipeline ---\")\n\n    # 1. Data Loading\n    try:\n        df = data_loader.load_data(file_path)\n        print(f\"Data loaded successfully. Shape: {df.shape}\")\n    except FileNotFoundError:\n        print(f\"Error: File not found at {file_path}. Analysis stopped.\")\n        return\n    except Exception as e:\n        print(f\"Error during data loading: {e}. Analysis stopped.\")\n        return\n\n    # 2. Preprocessing\n    try:\n        sales_trends, item_type_summary = preprocessing.preprocess(df)\n        print(\"Preprocessing successful.\")\n    except Exception as e:\n        print(f\"Error during preprocessing: {e}. Analysis stopped.\")\n        return\n\n    # 3. Analysis and Summary Generation\n    print(\"\\n=========================================\")\n    print(\"         ANALYSIS SUMMARY\")\n    print(\"=========================================\")\n\n    # Textual Summary: Year-over-Year Trend Analysis\n    if not sales_trends.empty:\n        print(\"\\nKey Finding: Total Sales Trend Over Years\")\n        print(sales_trends.sort_values(by='YEAR').to_string(index=False, float_format=\"%.2f\"))\n        \n        # Observation based on the trend\n        if len(sales_trends) > 1:\n            start_sales = sales_trends.iloc[0]['Total Retail Sales']\n            end_sales = sales_trends.iloc[-1]['Total Retail Sales']\n            growth = ((end_sales - start_sales) / start_sales) * 100\n            print(f\"\\nObservation: Retail Sales showed a growth of {growth:.2f}% from the first recorded year to the last recorded year.\")\n    else:\n        print(\"No time series data available for trend analysis.\")\n\n    # Summary based on Item Type\n    print(\"\\nSales Summary by Item Type (Total Sales):\")\n    print(item_type_summary.sort_values(by='Total Sales', ascending=False).to_string(index=False, float_format=\"%.2f\"))\n\n\n    # 4. Visualization\n    print(\"\\nGenerating Visualization...\")\n    try:\n        # Generate a time series plot of total sales\n        figures.plot_sales_trend(sales_trends, title=\"Total Sales Trend Over Time (Years)\")\n        print(\"Visualization successfully generated.\")\n    except Exception as e:\n        print(f\"Error during figure generation: {e}\")\n\n    print(\"\\n--- Analysis Complete ---\")\n\n\nif __name__ == '__main__':\n    # Execution entry point, assuming the file is run locally with the required CSV present.\n    # Note: For execution in a true sandbox environment, file path handling must be precise.\n    INPUT_FILE = 'Warehouse_and_Retail_Sales.csv'\n    run_analysis(INPUT_FILE)",
