{
  "backend": "ollama",
  "content": "import pandas as pd\n\ndef run_analysis(data: dict) -> dict:\n    \"\"\"\n    Analyzes sales performance from preprocessed monthly data to identify \n    seasonal trends and item type performance.\n\n    Args:\n        data: A dictionary containing preprocessed DataFrame(s). \n              Expected key: 'monthly_sales_summary'.\n\n    Returns:\n        A dictionary containing result DataFrames, specifically \n        'seasonal_sales_by_item_type'.\n    \"\"\"\n    df_summary = data.get('monthly_sales_summary')\n\n    if df_summary is None:\n        return {}\n\n    # 1. Calculate total sales for the analysis: \n    # We sum RETAIL SALES, WAREHOUSE SALES, and RETAIL TRANSFERS \n    # to get a comprehensive picture of activity.\n    df_summary['TOTAL_SALES'] = (\n        df_summary['RETAIL SALES'] + \n        df_summary['WAREHOUSE SALES'] + \n        df_summary['RETAIL TRANSFERS']\n    )\n\n    # 2. Analyze Seasonal Sales by Item Type\n    # We aggregate the total sales over the entire observed period, \n    # grouped by YEAR and ITEM TYPE to show item performance across time.\n    # We keep YEAR because the key output requires 'seasonal_sales_by_item_type'.\n    seasonal_sales = df_summary.groupby(['YEAR', 'ITEM TYPE'])['TOTAL_SALES'].sum().reset_index(name='TOTAL_ITEM_SALES')\n\n    # The primary required output DataFrame\n    results = {\n        'seasonal_sales_by_item_type': seasonal_sales\n    }\n\n    # Note: While overall summaries and trends could be calculated here, \n    # we adhere strictly to the output contract required by the sandbox: \n    # returning only the specific requested result table.\n    \n    return results",
