    "response": "import pandas as pd\nfrom typing import Dict, Any\n\ndef preprocess(data: Dict[str, pd.DataFrame]) -> Dict[str, pd.DataFrame]:\n    \"\"\"\n    Cleans, aggregates, and engineers the raw sales transaction data.\n    The data is summarized by Year, Month, Item Type, and Supplier,\n    and a total sales column is created for downstream trend analysis.\n\n    Args:\n        data: A dictionary containing raw DataFrames. Expects the key \n              'warehouse_and_retail_sales'.\n\n    Returns:\n        A dictionary containing the aggregated DataFrame under the key 'monthly_sales_summary'.\n    \"\"\"\n    # Check for required input data key\n    RAW_DATA_KEY = 'warehouse_and_retail_sales'\n    if RAW_DATA_KEY not in data:\n        raise ValueError(f\"Input data dictionary must contain '{RAW_DATA_KEY}'.\")\n\n    df = data[RAW_DATA_KEY].copy()\n\n    # Define grouping keys (dimensions) and metric columns (values)\n    aggregation_keys = ['YEAR', 'MONTH', 'ITEM TYPE', 'SUPPLIER']\n    metric_columns = ['RETAIL SALES', 'RETAIL TRANSFERS', 'WAREHOUSE SALES']\n\n    # 1. Aggregate the data: Sum all sales metrics by the defined dimensions.\n    # This groups transactions into monthly, item-specific summaries.\n    try:\n        aggregated_df = df.groupby(aggregation_keys)[metric_columns].sum().reset_index()\n    except KeyError as e:\n        raise ValueError(f\"One or more required columns are missing for aggregation: {e}\")\n\n\n    # 2. Feature Engineering: Calculate the total sales volume.\n    # Using direct arithmetic operations is efficient for sum calculation.\n    aggregated_df['TOTAL SALES'] = (\n        aggregated_df['RETAIL SALES'] + \n        aggregated_df['RETAIL TRANSFERS'] + \n        aggregated_df['WAREHOUSE SALES']\n    )\n\n    # 3. Select and order the final set of columns for consistency and readability.\n    # The order reflects the logical flow: Time -> Summary Metrics -> Dimensions\n    final_columns = [\n        'YEAR', \n        'MONTH', \n        'TOTAL SALES', \n        'RETAIL SALES', \n        'RETAIL TRANSFERS', \n        'WAREHOUSE SALES', \n        'ITEM TYPE', \n        'SUPPLIER'\n    ]\n    \n    # Filter the DataFrame to include only the necessary and calculated columns.\n    # We ensure that the columns exist before attempting selection.\n    existing_final_columns = [col for col in final_columns if col in aggregated_df.columns]\n    processed_df = aggregated_df[existing_final_columns].copy()\n\n    # Return the data under the key specified by the shared bundle contract.\n    return {\n        'monthly_sales_summary': processed_df\n    }\n",
