  "content": "import pandas as pd\nfrom typing import Dict\n\ndef preprocess(data: Dict[str, pd.DataFrame]) -> Dict[str, pd.DataFrame]:\n    \"\"\"\n    Preprocesses the raw sales and inventory data by extracting and structuring\n    the required columns.\n\n    Args:\n        data: A dictionary where keys correspond to column names (source DF names)\n              and values are pandas DataFrames loaded from the input.\n\n    Returns:\n        A dictionary containing the processed DataFrames, keyed by the required\n        column names: YEAR, MONTH, SUPPLIER, ITEM CODE, ITEM DESCRIPTION, \n        ITEM TYPE, RETAIL SALES, RETAIL TRANSFERS, WAREHOUSE SALES.\n    \"\"\"\n    processed_data = {}\n\n    required_columns = [\n        'YEAR', 'MONTH', 'SUPPLIER', 'ITEM CODE', 'ITEM DESCRIPTION', \n        'ITEM TYPE', 'RETAIL SALES', 'RETAIL TRANSFERS', 'WAREHOUSE SALES'\n    ]\n\n    for col_name, df in data.items():\n        if not isinstance(df, pd.DataFrame):\n            continue\n            \n        # Check if the DataFrame contains all necessary core columns\n        if all(col in df.columns for col in required_columns):\n            df_copy = df[required_columns].copy()\n            \n            # Store the subset of required columns under their respective names.\n            # If multiple input DFs exist, this structure ensures we capture all relevant fields.\n            for col in required_columns:\n                # We store the entire required column as the processed DataFrame for that key.\n                # Note: Depending on the runtime orchestration, this might overwrite or merge data.\n                # For a safe implementation, we store the unique combination or the full subset.\n                processed_data[col] = df_copy[col]\n                \n            # Additional time-series preparation (optional, keeping it minimal as per contract focus)\n            if 'YEAR' in df_copy.columns and 'MONTH' in df_copy.columns:\n                # Create a combined date column for easier time-series plotting/aggregation\n                df_copy['DATE'] = pd.to_datetime(df_copy['YEAR'].astype(str) + '-' + df_copy['MONTH'].astype(str) + '-01')\n\n    return processed_data",
