  "content": "import pandas as pd\nfrom typing import Dict\n\ndef preprocess(data: Dict[str, pd.DataFrame]) -> Dict[str, pd.DataFrame]:\n    \"\"\"\n    Preprocesses the raw sales and inventory data.\n\n    This function focuses on structuring the data for time-series analysis\n    and aggregation by ensuring correct data types and preparing base views\n    of the required columns based on the input dictionary structure.\n\n    Args:\n        data: A dictionary where keys correspond to column names and values are\n              pandas DataFrames loaded from the input.\n\n    Returns:\n        A dictionary containing the processed DataFrames, keyed by the original\n        column names.\n    \"\"\"\n    processed_data = {}\n\n    required_columns = [\n        'YEAR', 'MONTH', 'SUPPLIER', 'ITEM CODE', 'ITEM DESCRIPTION', \n        'ITEM TYPE', 'RETAIL SALES', 'RETAIL TRANSFERS', 'WAREHOUSE SALES'\n    ]\n\n    for col_name, df in data.items():\n        # Check if the DataFrame contains the necessary columns or is a relevant data source\n        if not isinstance(df, pd.DataFrame):\n            continue\n            \n        # Determine if this DataFrame contains the core information needed for the contract\n        if all(col in df.columns for col in required_columns):\n            df_copy = df.copy()\n            \n            # Ensure required columns are present in the output structure\n            for col in required_columns:\n                if col in df_copy.columns:\n                    processed_data[col] = df_copy[col]\n            \n            # Additional time-series preparation for aggregation potential\n            if 'YEAR' in df_copy.columns and 'MONTH' in df_copy.columns:\n                # Create a combined date column for easier time-series plotting/aggregation\n                df_copy['DATE'] = pd.to_datetime(df_copy['YEAR'].astype(str) + '-' + df_copy['MONTH'].astype(str) + '-01')\n                \n            # Store the dataframe corresponding to the primary key (col_name)\n            # We store the full processed frame under its original name as per common practice, \n            # or handle this by structuring the output dictionary based on the contract.\n            # For this specific contract, we map the original column name to the processed DF.\n            processed_data[col_name] = df_copy\n\n    return processed_data",
